# Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados
DATABASE_URL="postgresql://usuario:senha@localhost:5432/causa_animal?schema=public"

# JWT
JWT_SECRET=sua_chave_secreta_aqui_mude_em_producao
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=seu_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# AWS S3 (opcional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# WhatsApp API (opcional)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Google Maps
GOOGLE_MAPS_API_KEY=sua_api_key_aqui

# Frontend URL
FRONTEND_URL=http://localhost:3000
