{
  "name": "causa-animal-backend",
  "version": "1.0.0",
  "description": "API para sistema de causa animal",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node create-dirs.js && node src/server.js",
    "migrate": "npx prisma migrate deploy",
    "migrate:dev": "npx prisma migrate dev",
